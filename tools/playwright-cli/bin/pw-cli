#!/usr/bin/env python3
"""Stateless wrapper around Playwright CLI with deterministic JSON outputs."""

import argparse
import json
import shutil
import subprocess
import sys
from typing import Optional

WRAPPER_VERSION = "1.0.0"


def emit(status: str, output: str, path: Optional[str] = None, exit_code: int = 0) -> int:
    payload = {
        "status": status,
        "output": output,
        "path": path or "",
    }
    print(json.dumps(payload, ensure_ascii=True, sort_keys=True))
    return exit_code


def playwright_base_cmd() -> list[str]:
    if shutil.which("playwright"):
        return ["playwright"]
    if shutil.which("npx"):
        return ["npx", "-y", "@playwright/cli"]
    return []


def run_playwright(cmd: list[str], path: Optional[str] = None) -> int:
    if not cmd:
        return emit("error", "no playwright command configured", path=path, exit_code=1)
    try:
        proc = subprocess.run(cmd, capture_output=True, text=True, check=False)
    except FileNotFoundError:
        return emit("error", "playwright binary not found in PATH", path=path, exit_code=1)

    output = (proc.stdout or "").strip() or (proc.stderr or "").strip()
    if proc.returncode == 0:
        return emit("success", output, path=path, exit_code=0)
    return emit("error", output or f"command failed with exit code {proc.returncode}", path=path, exit_code=proc.returncode)


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="pw-cli",
        description="Deterministic JSON wrapper for core Playwright CLI commands",
    )
    parser.add_argument("--version", action="store_true", help="Show wrapper and Playwright version")
    parser.add_argument("--json", action="store_true", help="Compatibility flag; output is always JSON")

    subparsers = parser.add_subparsers(dest="command")

    subparsers.add_parser("install", help="Install Playwright browser binaries")

    screenshot = subparsers.add_parser("screenshot", help="Capture page screenshot")
    screenshot.add_argument("--url", required=True, help="Target URL")
    screenshot.add_argument("--path", required=True, help="Output screenshot path")

    pdf = subparsers.add_parser("pdf", help="Export page PDF")
    pdf.add_argument("--url", required=True, help="Target URL")
    pdf.add_argument("--path", required=True, help="Output PDF path")

    codegen = subparsers.add_parser("codegen", help="Launch Playwright code generator")
    codegen.add_argument("--url", required=True, help="Target URL")
    codegen.add_argument(
        "--path",
        default="playwright.codegen.ts",
        help="Output script path for generated Playwright code",
    )

    return parser


def main() -> int:
    parser = build_parser()
    args = parser.parse_args()
    base = playwright_base_cmd()

    if args.version:
        if not base:
            return emit("error", "playwright command is unavailable (expected playwright or npx)", exit_code=1)
        return run_playwright(base + ["--version"])

    if args.command == "install":
        if not base:
            return emit("error", "playwright command is unavailable (expected playwright or npx)", exit_code=1)
        return run_playwright(base + ["install"])

    if args.command == "screenshot":
        if not base:
            return emit("error", "playwright command is unavailable (expected playwright or npx)", path=args.path, exit_code=1)
        return run_playwright(base + ["screenshot", args.url, args.path], path=args.path)

    if args.command == "pdf":
        if not base:
            return emit("error", "playwright command is unavailable (expected playwright or npx)", path=args.path, exit_code=1)
        return run_playwright(base + ["pdf", args.url, args.path], path=args.path)

    if args.command == "codegen":
        if not base:
            return emit("error", "playwright command is unavailable (expected playwright or npx)", path=args.path, exit_code=1)
        try:
            proc = subprocess.Popen(
                base + ["codegen", "--output", args.path, args.url],
                stdin=subprocess.DEVNULL,
                stdout=subprocess.DEVNULL,
                stderr=subprocess.DEVNULL,
                start_new_session=True,
            )
            return emit(
                "success",
                f"codegen session started (pid={proc.pid}); close it when script capture is complete",
                path=args.path,
                exit_code=0,
            )
        except FileNotFoundError:
            return emit("error", "playwright binary not found in PATH", path=args.path, exit_code=1)
        except OSError as exc:
            return emit("error", f"failed to start codegen: {exc}", path=args.path, exit_code=1)

    parser.print_help()
    return 0


if __name__ == "__main__":
    sys.exit(main())
