#!/usr/bin/env python3
import argparse
import json
import shutil
import subprocess
import sys
from pathlib import Path
from typing import Any, Dict, List, Optional

VERSION = "1.0.0"


def emit(payload: Dict[str, Any], code: int = 0) -> int:
    print(json.dumps(payload, indent=2))
    return code


def run_cmd(cmd: List[str], env: Optional[Dict[str, str]] = None) -> subprocess.CompletedProcess:
    return subprocess.run(cmd, capture_output=True, text=True, check=False, env=env)


def read_payload(payload: Optional[str], payload_file: Optional[str]) -> str:
    if payload and payload_file:
        raise ValueError("Provide either --payload or --payload-file, not both")
    if payload:
        json.loads(payload)
        return payload
    if payload_file:
        file_path = Path(payload_file)
        if not file_path.exists():
            raise FileNotFoundError(f"payload file not found: {payload_file}")
        raw = file_path.read_text(encoding="utf-8")
        json.loads(raw)
        return raw
    raise ValueError("--payload or --payload-file is required")


def main() -> int:
    parser = argparse.ArgumentParser(description="n8n webhook trigger bridge via n8n")
    parser.add_argument("command", nargs="?", default="trigger", choices=["trigger"])
    parser.add_argument("--workflow", required=False)
    parser.add_argument("--payload", required=False)
    parser.add_argument("--payload-file", required=False)
    parser.add_argument("--json", action="store_true")
    parser.add_argument("--version", action="store_true")
    args = parser.parse_args()

    if args.version:
        return emit({"status": "success", "output": VERSION})

    if not args.workflow:
        return emit({"status": "error", "output": "--workflow is required"}, 1)

    n8n_bin = shutil.which("n8n")
    if not n8n_bin:
        return emit({"status": "error", "output": "n8n executable not found in PATH"}, 1)

    try:
        payload = read_payload(args.payload, args.payload_file)
        cmd = [n8n_bin, "trigger", "--workflow-id", args.workflow, "--payload-json", payload, "--json"]
        res = run_cmd(cmd)
        if res.returncode != 0:
            return emit(
                {
                    "status": "error",
                    "output": "n8n trigger failed",
                    "stderr": res.stderr.strip(),
                    "path": "n8n trigger"
                },
                1,
            )

        try:
            n8n_payload = json.loads(res.stdout)
        except json.JSONDecodeError:
            n8n_payload = {"raw": res.stdout.strip()}

        return emit(
            {
                "status": "success",
                "output": "Workflow triggered",
                "workflow": args.workflow,
                "path": "n8n trigger",
                "result": n8n_payload
            }
        )

    except Exception as exc:
        return emit({"status": "error", "output": str(exc), "path": "n8n trigger"}, 1)


if __name__ == "__main__":
    sys.exit(main())
