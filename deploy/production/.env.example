LOGIC_ENGINE_HOST=0.0.0.0
LOGIC_ENGINE_PORT=8081
LOGIC_ENGINE_ENV=production
LOGIC_ENGINE_SECRET_PROVIDER=gsm
LOGIC_ENGINE_ALLOW_NONPROD_SECRET_FALLBACK=false

GCP_PROJECT_ID=replace-with-project-id
GOOGLE_CLOUD_PROJECT=replace-with-project-id
GOOGLE_APPLICATION_CREDENTIALS=/var/secrets/google/linktrend-gsm.json

LOGIC_ENGINE_TOKEN_SECRET_SECRET_NAME=LOGIC_ENGINE_TOKEN_SECRET
LINKSKILLS_API_KEY_AIOS_SECRET_NAME=LINKSKILLS_API_KEY_AIOS
LINKSKILLS_API_KEY_AUTOWORK_SECRET_NAME=LINKSKILLS_API_KEY_AUTOWORK

LOGIC_ENGINE_REPO_ROOT=/app
LOGIC_ENGINE_DATA_PATH=/app/services/logic-engine/runtime/store.json
LOGIC_ENGINE_GSM_SECRET_FILE=/app/services/logic-engine/runtime/gsm-secrets.json
