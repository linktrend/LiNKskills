# Ignore local task state and raw traces
.workdir/
**/trace.log
**/state.json
**/state.jsonl

# Ignore system-specific files
.DS_Store
__pycache__/
*.pyc

# LTR Runtime Identity Isolation
tools/ltr/src/token.json
tools/ltr/src/credentials.json
tools/ltr/src/__pycache__/
tools/ltr/src/*.log
tools/ltr/src/venv/

# Fortress security storage
tools/vault/data/*.bin
**/token.json

# LiNKskills runtime artifacts (non-source-of-truth)
services/logic-engine/runtime/*.json
services/logic-engine/runtime/*.jsonl
services/logic-engine/runtime/*.log
